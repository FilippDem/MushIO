# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.spec           # PyInstaller (archived)

# ── Host runtime files ────────────────────────────────────────────────────────
host/settings.json        # per-machine paths; user generates on first run
host/mushio_recovery_*.bin  # rolling recovery buffers (regenerated each session)
data/                     # raw binary recording output (can be very large)
firmware_c/data/          # firmware-side recorded data
captures/                 # webcam captures

# ── Firmware C build artefacts ────────────────────────────────────────────────
firmware_c/build/
firmware_c/build2/

# ── Firmware config override (generated at flash time) ────────────────────────
firmware_c/_flash_config_override.py

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Misc junk ─────────────────────────────────────────────────────────────────
nul
*.log
